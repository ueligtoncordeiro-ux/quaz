{
  "name": "quaz-di-graca",
  "version": "0.1.0",
  "private": true,
  "description": "Marketplace antidesperdicio Quaz di Graca.",
  "scripts": {
    "dev": "npm run dev --workspace @quaz/web",
    "dev:app": "npm run dev --workspace @quaz/app -- --port 3002",
    "build": "npm run build --workspace @quaz/web",
    "build:app": "npm run build --workspace @quaz/app",
    "lint": "npm run lint --workspace @quaz/web",
    "lint:app": "npm run lint --workspace @quaz/app",
    "typecheck:app": "npm run typecheck --workspace @quaz/app",
